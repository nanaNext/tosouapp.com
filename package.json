{
  "name": "attendance-backend",
  "version": "1.0.0",
  "main": "attendance/backend/src/server.js",
  "scripts": {
    "start": "node attendance/backend/src/server.js",
    "start:prod:local": "set PORT=3000&& set APP_ENV=&& set DISABLE_SCHEDULERS=&& node attendance/backend/src/server.js",
    "start:staging": "set APP_ENV=staging&& set NODE_ENV=production&& set PORT=3001&& set DISABLE_SCHEDULERS=true&& node attendance/backend/src/server.js",
    "test": "jest",
    "test:unit": "node --max-old-space-size=2048 ./node_modules/jest/bin/jest.js --testPathIgnorePatterns=/e2e-playwright/ -- attendance/backend/tests",
    "test:integration": "node --max-old-space-size=2048 ./node_modules/jest/bin/jest.js --testPathIgnorePatterns=/e2e-playwright/ -- attendance/backend/tests/integration",
    "test:e2e": "jest attendance/backend/tests/e2e",
    "test:e2e:pw": "playwright test",
    "test:smoke": "jest attendance/backend/tests/e2e/basic.test.js",
    "test:quick": "npm run test:unit && npm run test:integration",
    "test:e2e:local": "playwright test --base-url http://localhost:3000",
    "docker:db": "docker compose -f attendance/backend/docker/docker-compose.yml up -d db",
    "docker:up:api": "docker compose -f attendance/backend/docker/docker-compose.yml up -d api",
    "docker:down": "docker compose -f attendance/backend/docker/docker-compose.yml down",
    "docker:up:stg": "docker compose -f attendance/backend/docker/docker-compose.yml up -d api-staging",
    "docker:up:nginx": "docker compose -f attendance/backend/docker/docker-compose.yml up -d nginx",
    "docker:promote:prod": "powershell -Command \"$env:APP_BACKEND='api:3000'; docker compose -f attendance/backend/docker/docker-compose.yml up -d nginx\"",
    "docker:promote:stg": "powershell -Command \"$env:APP_BACKEND='api-staging:3001'; docker compose -f attendance/backend/docker/docker-compose.yml up -d nginx\"",
    "perf:k6": "docker run --rm -e BASE=http://localhost:3000 -e USER_ID=5 -e MONTH=2026-03 -e ADMIN_EMAIL=admin@example.com -e ADMIN_PASSWORD=secret -v %cd%/attendance/backend/scripts/k6:/scripts grafana/k6:latest run /scripts/payslip_load_test.js",
    "db:migrate": "knex migrate:latest --knexfile attendance/backend/knexfile.js",
    "db:seed": "knex seed:run --knexfile attendance/backend/knexfile.js",
    "db:migrate:make": "knex migrate:make --knexfile attendance/backend/knexfile.js",
    "db:backup": "node attendance/backend/scripts/db-backup.js",
    "frontend:dev": "vite --config attendance/frontend/vite.config.js",
    "frontend:build": "vite build --config attendance/frontend/vite.config.js"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-validator": "^7.3.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.0",
    "mysql2": "^3.18.2",
    "pdfkit": "^0.17.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "@simplewebauthn/server": "^10.0.0"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "vite": "^5.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "supertest": "^7.0.0",
    "@playwright/test": "^1.43.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.11.30",
    "@types/jest": "^29.5.12",
    "knex": "^3.1.0",
    "mysqldump": "^3.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@mui/material": "^5.15.14",
    "@mui/icons-material": "^5.15.14",
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@reduxjs/toolkit": "^2.2.3",
    "react-redux": "^9.1.0"
  },
  "overrides": {
    "tar": ">=7.5.11",
    "@mapbox/node-pre-gyp": {
      "tar": ">=7.5.11"
    }
  }
}
