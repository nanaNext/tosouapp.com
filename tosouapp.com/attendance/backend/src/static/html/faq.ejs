<!doctype html>
<html lang="ja">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=0.75,minimum-scale=0.75,maximum-scale=3,user-scalable=yes">
  <title>よくある質問</title>
  <link rel="stylesheet" href="/static/css/base.css?v=navy-20260408-1">
  <link rel="stylesheet" href="/static/css/attendance.css?v=navy-20260424-2">
  <link rel="stylesheet" href="/static/css/attendance-monthly.css?v=navy-20260416-1">
  <link rel="icon" href="data:,">
  <script src="/static/js/pages/session-idle.js?v=navy-20260403-1" defer></script>
  <script src="/static/js/pages/kintai-topbar-links.js?v=navy-20260427-5" defer></script>
  <script src="/static/js/pages/faq.page.js?v=navy-20260502-faqcsp1" defer></script>
</head>
<body>
  <header class="kintai-top">
    <div class="kintai-top-inner">
      <div class="kintai-brand">
        <div class="kintai-logo">スマートE勤怠</div>
      </div>
      <nav class="kintai-nav" aria-label="main">
        <div class="kintai-nav-dd">
          <button class="kintai-nav-btn" type="button" data-dd="att" aria-haspopup="true" aria-expanded="false">
            勤怠入力 <span class="kintai-caret">▾</span>
          </button>
          <div class="kintai-dd" data-dd-panel="att" hidden>
            <a href="/ui/attendance?back=1">個人カレンダー登録画面</a>
            <a href="/ui/attendance/monthly">月次勤怠入力へ</a>
            <a href="/ui/attendance/simple">簡易登録画面</a>
          </div>
        </div>
        <div class="kintai-nav-dd">
          <button class="kintai-nav-btn" type="button" data-dd="leave" aria-haspopup="true" aria-expanded="false">
            有休管理 <span class="kintai-caret">▾</span>
          </button>
          <div class="kintai-dd" data-dd-panel="leave" hidden>
            <a href="/ui/leave-ledger">休暇欠勤台帳</a>
          </div>
        </div>
        <div class="kintai-nav-dd">
          <button class="kintai-nav-btn active" type="button" data-dd="common" aria-haspopup="true" aria-expanded="false">
            共通機能 <span class="kintai-caret">▾</span>
          </button>
          <div class="kintai-dd" data-dd-panel="common" hidden>
            <a href="/ui/change-password">パスワード変更画面</a>
          </div>
        </div>
      </nav>
      <div class="kintai-user">
        <div class="kintai-top-links">
          <a class="kintai-top-link" href="/ui/manual">操作マニュアル</a>
          <a class="kintai-top-link" href="/ui/faq">よくある質問</a>
          <a class="kintai-top-link logout-link" href="/ui/logout">ログアウト</a>
        </div>
      </div>
    </div>
  </header>  <main class="kintai-main">
    <section class="kintai-grid" style="max-width:1000px;margin:0 auto;padding:20px;">
      <!-- Title -->
      <div class="kintai-card" style="margin-bottom:20px;">
        <div class="kintai-card-title">よくある質問</div>
        <div style="padding:20px;color:#334155;">
          <p style="margin:0;">
            本ページでは、よくあるご質問と回答をまとめています。
            <br>
            ご質問がありましたら、下部のフォームからお気軽にお問い合わせください。
          </p>
        </div>
      </div>

      <!-- Category Tabs -->
      <div style="display:flex;gap:10px;margin-bottom:20px;flex-wrap:wrap;padding:0 20px;">
        <button class="faq-tab-btn active" data-category="all" style="padding:8px 16px;border:none;border-radius:6px;background:#1e40af;color:white;cursor:pointer;font-size:13px;font-weight:500;">
          すべて
        </button>        <button class="faq-tab-btn" data-category="ログイン" style="padding:8px 16px;border:1px solid #ddd;border-radius:6px;background:white;cursor:pointer;font-size:13px;">
          ログイン
        </button>
        <button class="faq-tab-btn" data-category="勤怠入力" style="padding:8px 16px;border:1px solid #ddd;border-radius:6px;background:white;cursor:pointer;font-size:13px;">
          勤怠入力
        </button>
        <button class="faq-tab-btn" data-category="有休管理" style="padding:8px 16px;border:1px solid #ddd;border-radius:6px;background:white;cursor:pointer;font-size:13px;">
          有休管理
        </button>
        <button class="faq-tab-btn" data-category="技術的な問題" style="padding:8px 16px;border:1px solid #ddd;border-radius:6px;background:white;cursor:pointer;font-size:13px;">
          技術的な問題
        </button>
      </div>

      <!-- FAQ Items -->
      <div id="faqContainer" style="margin-bottom:40px;">
        <div style="text-align:center;padding:40px;color:#999;">
          <div style="font-size:14px;">読み込み中...</div>
        </div>
      </div>

      <!-- Question Form -->
      <div class="kintai-card" style="margin-bottom:30px;background:#f9f9f9;">
        <div class="kintai-card-title" style="background:#1e40af;color:white;">❓ ご質問がございましたら</div>
        <div style="padding:20px;">
          <p style="margin:0 0 20px 0;color:#334155;font-size:14px;">
            上記の「よくある質問」に該当する質問がない場合は、以下のフォームからご質問ください。
            管理者が確認後、ご回答させていただきます。
          </p>

          <form id="questionForm" style="display:grid;gap:15px;">
            <div>
              <label style="display:block;margin-bottom:5px;font-weight:bold;color:#334155;font-size:14px;">
                質問カテゴリー（任意）
              </label>
              <select id="categorySelect" style="width:100%;padding:8px;border:1px solid #ddd;border-radius:6px;font-size:13px;">
                <option value="">選択してください</option>
                <option value="ログイン">ログイン</option>
                <option value="勤怠入力">勤怠入力</option>
                <option value="有休管理">有休管理</option>
                <option value="技術的な問題">技術的な問題</option>
                <option value="その他">その他</option>
              </select>
            </div>

            <div>
              <label style="display:block;margin-bottom:5px;font-weight:bold;color:#334155;font-size:14px;">
                質問タイトル <span style="color:red;">*</span>
              </label>
              <input 
                id="questionInput" 
                type="text" 
                placeholder="例：打刻ボタンが押せません"
                style="width:100%;padding:10px;border:1px solid #ddd;border-radius:6px;font-size:13px;box-sizing:border-box;"
                required
              />
              <div style="font-size:11px;color:#999;margin-top:5px;">
                5文字以上500文字以下
              </div>
            </div>

            <div>
              <label style="display:block;margin-bottom:5px;font-weight:bold;color:#334155;font-size:14px;">
                詳細（任意）
              </label>
              <textarea 
                id="detailInput" 
                placeholder="詳しい状況や画面のエラーメッセージなど（2000文字以下）"
                style="width:100%;padding:10px;border:1px solid #ddd;border-radius:6px;font-size:13px;min-height:120px;resize:vertical;box-sizing:border-box;font-family:inherit;"
              ></textarea>
            </div>            <div style="display:flex;gap:10px;">
              <button 
                type="submit" 
                style="flex:1;padding:12px;background:#28a745;color:white;border:none;border-radius:6px;font-weight:bold;cursor:pointer;font-size:14px;transition: all 0.2s;"
              >
                ✉️ 質問を送信
              </button>
              <button 
                type="reset" 
                style="flex:0 0 120px;padding:12px;background:#ccc;color:#333;border:none;border-radius:6px;cursor:pointer;font-size:14px;"
              >
                クリア
              </button>
            </div>
          </form>

          <!-- My Questions -->
          <div style="margin-top:30px;padding-top:30px;border-top:1px solid #ddd;">
            <div style="font-weight:bold;color:#334155;margin-bottom:15px;font-size:14px;">
              📝 あなたの質問（<span id="myQuestionsCount">0</span>件）
            </div>
            <div id="myQuestionsContainer" style="display:grid;gap:12px;">
              <div style="text-align:center;color:#999;padding:20px;">
                質問がまだありません
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

</body>
</html>


