<header class="topbar">
  <button id="mobileMenuBtn" class="mobile-btn" aria-label="menu" aria-expanded="false" aria-controls="mobileDrawer">☰</button>
  <div class="topbar-inner">
    <%- include('admin-brand.ejs') %>
    <div class="search">
      <div class="search-prefix"><span class="ico">⚙</span><span class="txt">Projects</span></div>
      <input type="search" id="globalSearchInputAdmin" name="q" placeholder="Search..." aria-label="Search">
      <span class="search-hint" aria-hidden="true">^ K</span>
      <div class="search-meta" aria-hidden="true">
        <button type="button" class="search-close" title="Close">×</button>
        <span class="search-esc">ESC</span>
      </div>
    </div>
    <div class="topbar-actions">
      <button type="button" class="icon-btn" id="btnAdminNew">+ New</button>
      <a href="/ui/admin-manual" class="icon-btn" id="btnAdminManual" style="text-decoration: none; color: inherit; display: inline-flex; align-items: center;">マニュアル</a>
      <button type="button" class="icon-btn" id="btnAdminHelp">?</button>
      <button type="button" class="icon-btn notify-btn" id="btnAdminNotify" aria-label="通知" aria-haspopup="true" aria-expanded="false">
        <span class="notify-bell" aria-hidden="true">🔔</span>
        <span class="notify-badge" id="adminNotifyBadge" hidden>0</span>
      </button>
    </div>
    <%- include('admin-user-menu.ejs') %>
  </div>
  <button id="emergencyUserBtn" type="button" aria-label="user" hidden>U</button>
</header>
<script type="module" src="/static/js/admin/admin-topbar.notify.js?v=navy-20260509-topbar17" defer></script>
