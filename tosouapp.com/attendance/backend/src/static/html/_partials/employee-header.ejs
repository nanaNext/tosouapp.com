  <header class="topbar">
    <button id="mobileMenuBtn" class="mobile-btn" aria-label="menu" aria-expanded="false" aria-controls="mobileDrawer">☰</button>
    <div class="topbar-inner">
      <a href="/ui/portal" class="brand" style="text-decoration: none;">
        <img src="/static/images/logo1.png?v=<%= appVersion %>" alt="logo" class="icon">
        <span class="logo">IIZUKA</span>
      </a>
      <div class="search" style="max-width: 400px; margin: 0 auto;">
      <input type="search" id="globalSearchInputEmp" name="q" placeholder="Search..." aria-label="Search">
      <span class="search-hint" aria-hidden="true">⌘ K</span>
        <div class="search-meta" aria-hidden="true">
          <button class="search-close" title="Close" type="button">×</button>
          <span class="search-esc">ESC</span>
        </div>
      </div>
      <div class="user" style="padding-right: 0px; margin-right: -24px; margin-left: 12px; transform: translateX(10px);">
        <div class="user-menu">
          <button class="user-btn" aria-haspopup="true" aria-expanded="false">
            <img src="/static/images/use.png?v=<%= appVersion %>" alt="user" class="user-icon" width="30" height="30" style="width: 30px; height: 30px; display: block; object-fit: cover;">
            <span id="userName" style="display: inline-block; min-width: 50px; text-align: left;"><%= typeof user !== 'undefined' && user ? (user.username || user.email || '') : '' %></span>
            <script>
              try {
                var rawUser = sessionStorage.getItem('user') || localStorage.getItem('user');
                if (rawUser) {
                  var u = JSON.parse(rawUser);
                  if (u && (u.username || u.email)) {
                    var el = document.getElementById('userName');
                    var next = u.username || u.email;
                    if (el.textContent !== next) {
                      el.textContent = next;
                    }
                  }
                }
              } catch(e) {}
            </script>
            <span class="caret">▾</span>
          </button>
          <div class="dropdown" id="userDropdown" hidden>
            <a href="/ui/dashboard" class="item">現在の登録情報</a>
            <button class="item" id="btnLogout" type="button">ログアウト</button>
          </div>
        </div>
      </div>
    </div>
  </header>
  <div id="drawerBackdrop" class="drawer-backdrop" hidden></div>
  <div id="mobileDrawer" class="mobile-drawer" hidden>
    <div class="drawer-header">
      <button id="mobileClose" class="mobile-close" aria-label="close">✕</button>
    </div>
    <a href="/ui/portal" class="drawer-item">ホーム</a>
    <a href="/ui/attendance-records" class="drawer-item">勤怠記録</a>
    <a href="/ui/shifts" class="drawer-item">シフト登録</a>
    <a href="/ui/contact" class="drawer-item">お問い合わせ先</a>
    <a href="/ui/logout" id="drawerLogout" class="drawer-item">ログアウト</a>
  </div>
  <div class="subbar">
    <nav class="subnav">
      <a href="/ui/portal">ホーム</a>
      <a href="/ui/attendance-records">勤怠記録</a>
      <a href="/ui/shifts">シフト登録</a>
      <a href="/ui/contact">お問い合わせ先</a>
    </nav>
  </div>
  <script nonce="<%= cspNonce %>">
    (function(){
      try {
        var path = window.location.pathname;
        var links = document.querySelectorAll('.subbar .subnav a, #mobileDrawer a.drawer-item');
        for(var i = 0; i < links.length; i++) {
          var href = links[i].getAttribute('href');
          if(href === path || (href !== '/' && path.indexOf(href) === 0)) {
            links[i].setAttribute('aria-current', 'page');
          }
        }
      } catch(e) {}
    })();
  </script>
