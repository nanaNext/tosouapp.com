  <!-- cache buster -->
  <script src="/static/js/pages/attendance-monthly.events.js?v=navy-20260703-3" defer></script>
  <script src="/static/js/pages/attendance-monthly.page.js?v=navy-20260703-3" defer></script>
</head>
<body class="nav-js">
  <div id="pageSpinner" class="kintai-spinner" hidden>
    <div class="lds-spinner" aria-hidden="true">
      <div></div><div></div><div></div><div></div><div></div><div></div>
      <div></div><div></div><div></div><div></div><div></div><div></div>
    </div>
    <div class="kintai-success-anim" aria-hidden="true"></div>
  </div>
  <div id="kintaiToast" class="kintai-toast" hidden aria-live="polite"></div>
  <header class="kintai-top">
    <div class="kintai-top-inner">
      <div class="kintai-brand">
        <div class="kintai-logo">スマートE勤怠</div>
      </div>
      <nav class="kintai-nav" aria-label="main">
        <div class="kintai-nav-dd">
          <button class="kintai-nav-btn active" type="button" data-dd="att" aria-haspopup="true" aria-expanded="false">
            勤怠入力 <span class="kintai-caret">▾</span>
          </button>
          <div class="kintai-dd" data-dd-panel="att" hidden>
            <a href="/ui/attendance?back=1">個人カレンダー登録画面</a>
            <a href="/ui/attendance/monthly">月次勤怠入力へ</a>
            <a href="/ui/attendance/simple">簡易登録画面</a>
          </div>
        </div>
        <div class="kintai-nav-dd">
          <button class="kintai-nav-btn" type="button" data-dd="leave" aria-haspopup="true" aria-expanded="false">
            有休管理 <span class="kintai-caret">▾</span>
          </button>
          <div class="kintai-dd" data-dd-panel="leave" hidden>
            <a href="/ui/leave-ledger">休暇欠勤台帳</a>
          </div>
        </div>
        <div class="kintai-nav-dd">
          <button class="kintai-nav-btn" type="button" data-dd="common" aria-haspopup="true" aria-expanded="false">
            共通機能 <span class="kintai-caret">▾</span>
          </button>
          <div class="kintai-dd" data-dd-panel="common" hidden>
            <a href="/ui/change-password">パスワード変更画面</a>
          </div>
        </div>
      </nav>
      <div class="kintai-user">
        <div class="kintai-top-links">
          <a class="kintai-top-link" href="/ui/manual">操作マニュアル</a>
          <a class="kintai-top-link" href="/ui/faq">よくある質問</a>
          <a class="kintai-top-link logout-link" href="/ui/logout">ログアウト</a>
        </div>
      </div>
    </div>
  </header>
  <main class="kintai-main">
    <div id="error" class="kintai-error" style="display:none;"></div>
    <div class="layout-container">
      <div class="layout-main">
        <div class="layout-header"></div>
        <div class="layout-contents">
          <form id="workingForm" action="#" method="post" enctype="multipart/form-data">
            <input type="hidden" name="_csrf" value="">
            <input type="hidden" name="formId" value="">
            <div id="workingStart" class="toggleTarget">
              <div class="se-page-head">
                <div class="se-page-title">月次勤怠入力</div>
                <div class="se-target-month">
                  <div class="se-target-label">対象年月</div>
                  <input id="monthPicker" class="se-target-input" type="month">
                  <select id="targetDateSelect" class="se-target-select" style="width:120px;"></select>
                </div>
              </div>
              <div class="se-employee-bar se-employee-bar-sample">
                <div class="se-employee-left">
                  <div class="se-avatar" aria-hidden="true"><img src="/static/images/use.png?v=<%= appVersion %>" alt="" class="se-avatar-img"></div>
                  <div class="se-employee-meta">
                    <div class="se-employee-line">
                      <span class="se-employee-k">社員番号</span>
                      <span class="se-employee-v" id="empCode">—</span>
                    </div>
                    <div class="se-employee-line">
                      <span class="se-employee-k">スタッフ名</span>
                      <span class="se-employee-v" id="staffName">—</span>
                    </div>
                    <div class="se-employee-line">
                      <span class="se-employee-k">オフィスコード</span>
                      <span class="se-employee-v" id="officeCode">—</span>
                    </div>
                    <div class="se-employee-line">
                      <span class="se-employee-k">オフィス名</span>
                      <span class="se-employee-v" id="officeName">—</span>
                    </div>
                    <div class="se-employee-line">
                      <span class="se-employee-k">所属</span>
                      <span class="se-employee-v" id="empDept">—</span>
                    </div>
                  </div>
                </div>
                <div class="se-target-month se-target-month-sample" aria-label="対象年月">
                  <div class="se-target-label-sample">対象年月</div>
                  <input id="monthPicker2" class="se-target-input-sample" type="month">
                </div>
              </div>
            </div>
            <div id="contractList" class="toggleTarget">
              <div class="se-shortcuts" aria-label="ショートカット">
                <a class="se-btn primary se-btn-wide" href="/ui/attendance/simple" style="text-decoration:none;display:inline-flex;align-items:center;gap:8px;">
                  <span aria-hidden="true">📱</span>
                  <span>簡易登録画面へ</span>
                </a>
              </div>
              <section class="se-section" id="contractSection">
                <div class="se-section-head se-contract-head">
                  <div class="se-daily-title">
                    <button type="button" class="se-daily-switch" id="contractToggle" aria-label="契約先一覧を折りたたむ" aria-pressed="false"></button>
                    <span class="se-daily-text">契約先一覧</span>
                  </div>
                  <div class="se-tabs se-tabs-seg" role="tablist" aria-label="契約先">
                    <button type="button" class="se-tab active" data-tab="contractDetail">契約内容</button>
                    <button type="button" class="se-tab" data-tab="workDetail">業務内容</button>
                  </div>
                </div>
                <div class="se-section-body">
                  <div id="contractTable" class="se-table"></div>
                  <div id="workDetailTable" class="se-table" hidden></div>
                </div>
              </section>
            </div>
            <div id="monthSummary" class="toggleTarget">
              <section class="se-section" id="summarySection">
                <div class="se-section-head se-summary-head">
                  <div class="se-daily-title">
                    <button type="button" class="se-daily-switch" id="summaryToggle" aria-label="当月サマリを折りたたむ" aria-pressed="false"></button>
                    <span class="se-daily-text">当月サマリ</span>
                  </div>
                  <div class="se-tabs se-tabs-seg" role="tablist" aria-label="サマリ対象">
                    <button type="button" class="se-tab active" data-tab="sumAll">全体</button>
                    <button type="button" class="se-tab" data-tab="sumInhouse">社内勤務</button>
                  </div>
                </div>
                <div class="se-section-body">
                  <div id="monthSummaryTable" class="se-summary" aria-live="polite"></div>
                </div>
              </section>
            </div>
            
            <div id="attendance" class="toggleTarget">
              <section class="se-section" id="dailySection">
                <div class="se-section-head se-daily-head">
                  <div class="se-daily-title">
                    <button type="button" class="se-daily-switch" id="dailyToggle" aria-label="日次実績を折りたたむ" aria-pressed="false"></button>
                    <span class="se-daily-text">日次実績</span>
                  </div>
                  <div class="se-daily-actions" style="display: flex; gap: 4px; margin-left: auto; align-items: center;">
                      <div class="se-tabs se-tabs-seg" role="tablist" aria-label="表示モード">
                        <button type="button" class="se-tab active" data-tab="actual">実績</button>
                        <button type="button" class="se-tab" data-tab="plan">予定</button>
                      </div>
                    </div>
                </div>
                <div class="se-section-body">
                  <div class="common-buttons">
                    <div class="se-toolbar">
                      <button type="button" class="se-btn primary se-btn-wide lastMonthBtn" id="btnPrevMonth">≪ 前月</button>
                      <button type="button" class="se-btn primary se-btn-wide nextMonthBtn" id="btnNextMonth">翌月 ≫</button>
                      <button type="button" class="se-btn primary se-btn-wide" id="btnExportWeek" disabled>就業状況通知書出力</button>
                      <button type="button" class="se-btn primary se-btn-wide" id="btnToggleGoOutHistory" style="background: #10b981; border-color: #10b981; margin-right: auto;" data-mode="daily">外出履歴を表示</button>
                      <a class="se-btn primary se-btn-wide" href="/ui/attendance?back=1" style="text-decoration:none;">個人カレンダー登録画面へ</a>
                    </div>
                  </div>
                  <div id="monthTable" class="se-table"></div>
                  <div id="goOutHistoryTable" class="se-table" style="display: none; margin-top: 12px;"></div>
                  
                </div>
              </section>
            </div>
            <div class="common-card w-100P"></div>
            <div class="dummy" style="margin: 33px"></div>
            <div id="yearSummary" class="toggleTarget">
              <section class="se-section" id="annualSection">
                <div class="se-section-head se-daily-head">
                  <div class="se-daily-title">
                    <button type="button" class="se-daily-switch" id="annualToggle" aria-label="年間サマリを折りたたむ" aria-pressed="false"></button>
                    <span class="se-daily-text">年間サマリ</span>
                  </div>
                </div>
                <div class="se-section-body">
                  <div id="yearSummaryTable" class="se-summary" aria-live="polite"></div>
                </div>
              </section>
            </div>
            <div class="dummy mar-b-10"></div>
            <div class="common-buttons fixed-contents-footer">
              <div class="se-bottombar">
                <button type="button" class="se-btn primary se-bottom-back" id="btnBackBottom">戻る</button>
                <div class="se-bottom-center">
                  <button type="button" class="se-btn primary exportBtn" id="btnExportMonthBottom" disabled>入力用Excel出力</button>
                  <input type="file" class="se-file" id="importFile" disabled>
                  <button type="button" class="se-btn primary importBtn" id="btnImportMonthBottom" disabled>入力用Excel取込</button>
                </div>
                <button type="button" class="se-btn primary se-bottom-confirm saveBtn" id="btnSaveBottom">保存</button>
              </div>
            </div>
          </form>
          <button type="button" data-toggle="modal" data-target="#workingHistoryModal" data-backdrop="static" id="showWorkingHistoryModalBtn" style="display: none"></button>
          <div id="workingHistoryModalTarget"></div>
          
          <div id="monthHScroll" class="se-hscroll" aria-hidden="true">
            <div class="se-hscroll-inner"></div>
          </div>
          <div id="monthVScroll" class="se-vscroll" aria-hidden="true">
            <div class="se-vscroll-inner"></div>
          </div>
        </div>
        <div class="layout-footer"></div>
      </div>
    </div>
    <div class="page-loading" style="display: none;"></div>

    <!-- 就業状況通知書 Modal -->
    <div id="employmentNoticeModal" class="enm-modal" hidden>
      <div class="enm-backdrop" id="enmBackdrop"></div>
      <div class="enm-content">
        <div class="enm-header">
          <h3>就業状況通知書</h3>
          <button type="button" class="enm-close" id="btnEnmClose" aria-label="閉じる">×</button>
        </div>
        <div class="enm-body" id="enmPrintArea">
          <div class="enm-paper">
            <div class="enm-title"><span>就業状況通知書</span></div>
            
            <div class="enm-info">
              <div class="enm-company">飯塚塗研株式会社</div>
              <div>作成日: <span id="enmDate"></span></div>
            </div>
            
            <table class="enm-table">
              <tr>
                <th style="width: 20%;">対象年月</th>
                <td style="width: 30%;" id="enmTargetMonth"></td>
                <th style="width: 20%;">社員番号</th>
                <td style="width: 30%;" id="enmEmpCode"></td>
              </tr>
              <tr>
                <th>氏名</th>
                <td id="enmEmpName"></td>
                <th>所属</th>
                <td id="enmEmpDept"></td>
              </tr>
            </table>

            <h4 style="margin: 0 0 10px 0; border-left: 4px solid #000; padding-left: 10px; font-size: 14px;">当月実績サマリ</h4>
            <table class="enm-table center-align">
              <tr>
                <th style="width: 16%;">所定労働日数</th>
                <th style="width: 16%;">出勤日数</th>
                <th style="width: 17%;">総労働時間</th>
                <th style="width: 17%;">時間外労働</th>
                <th style="width: 17%;">深夜労働時間</th>
                <th style="width: 17%;">休日労働時間</th>
              </tr>
              <tr>
                <td id="enmPlanDays"></td>
                <td id="enmAttendDays"></td>
                <td id="enmTotalWork"></td>
                <td id="enmOvertime"></td>
                <td id="enmNightWork"></td>
                <td id="enmHolidayWork"></td>
              </tr>
            </table>

            <h4 style="margin: 20px 0 10px 0; border-left: 4px solid #000; padding-left: 10px; font-size: 14px;">日次勤怠実績</h4>
            <table class="enm-daily-table" id="enmDailyTable">
              <thead>
                <tr>
                  <th rowspan="2" style="width: 5%;">日</th>
                  <th rowspan="2" style="width: 10%;">事由</th>
                  <th colspan="3" style="width: 12%;">就業場所</th>
                  <th colspan="2" style="width: 12%;">就業時間</th>
                  <th colspan="2" style="width: 12%;">休憩時間</th>
                  <th rowspan="2" style="width: 8%;">中抜け<br>時間</th>
                  <th rowspan="2" style="width: 8%;">勤務時間</th>
                  <th rowspan="2" style="width: 8%;">超過時間</th>
                  <th rowspan="2" style="width: 15%;">備考</th>
                  <th rowspan="2" style="width: 10%;">承認者</th>
                </tr>
                <tr>
                  <th>出社</th>
                  <th>在宅</th>
                  <th>出張</th>
                  <th>開始</th>
                  <th>終了</th>
                  <th>普通</th>
                  <th>深夜</th>
                </tr>
              </thead>
              <tbody>
                <!-- Rows will be injected here by JS -->
              </tbody>
            </table>

            <div style="margin-top: 30px; font-size: 14px; text-align: right; margin-bottom: 20px;">
              上記の通り、就業状況を通知いたします。
            </div>
          </div>
        </div>
        <div class="enm-footer">
          <button type="button" class="se-btn" id="btnEnmCloseBottom">閉じる</button>
          <button type="button" class="se-btn primary" id="btnEnmPrint">印刷 / PDF保存</button>
        </div>
      </div>
    </div>
  </main>
</body>
</html>

