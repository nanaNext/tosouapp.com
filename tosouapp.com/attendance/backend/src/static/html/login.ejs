<!doctype html>
<html lang="ja">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>WEB飯塚勤怠ログイン | 飯塚塗研株式会社</title>
    <meta name="description" content="飯塚塗研株式会社の勤怠・業務管理システムのログインページです。社員の勤怠入力、申請、交通費申請などを行えます。">
    <link rel="canonical" href="https://tosouapp.com/">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="飯塚塗研株式会社 勤怠管理システム">
    <meta property="og:title" content="WEB飯塚勤怠ログイン | 飯塚塗研株式会社">
    <meta property="og:description" content="飯塚塗研株式会社の勤怠・業務管理システムのログインページです。社員の勤怠入力、申請、交通費申請などを行えます。">
    <meta property="og:url" content="https://tosouapp.com/">
    <meta property="og:image" content="https://tosouapp.com/static/images/logo1.png">
    <link rel="stylesheet" href="/static/css/base.css?v=navy-20260416-1">
    <link rel="stylesheet" href="/static/css/login.css?v=navy-20260509-iconalign2">
    <script type="module" src="/static/js/pages/login.page.js?v=navy-20260424-policy4"></script>
    <link rel="icon" href="/static/images/logo1.png?v=<%= appVersion %>" type="image/png">
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "Organization",
            "name": "飯塚塗研株式会社",
            "alternateName": "Iizuka Token Co., Ltd.",
            "url": "https://www.iizuka-token.com",
            "logo": "https://tosouapp.com/static/images/logo1.png",
            "sameAs": [
              "https://www.iizuka-token.com"
            ]
          },
          {
            "@type": "WebApplication",
            "name": "WEB飯塚勤怠管理システム",
            "alternateName": "TosouApp",
            "url": "https://tosouapp.com/",
            "applicationCategory": "BusinessApplication",
            "operatingSystem": "Web",
            "description": "飯塚塗研株式会社の勤怠・業務管理システム。社員の勤怠入力、申請、交通費申請などを行えます。",
            "creator": {
              "@type": "Organization",
              "name": "飯塚塗研株式会社",
              "url": "https://www.iizuka-token.com"
            }
          },
          {
            "@type": "WebSite",
            "name": "飯塚塗研株式会社 勤怠管理",
            "alternateName": "TosouApp",
            "url": "https://tosouapp.com/",
            "publisher": {
              "@type": "Organization",
              "name": "飯塚塗研株式会社",
              "url": "https://www.iizuka-token.com"
            }
          }
        ]
      }
    </script>
</head>

<body>
    <div class="hero"></div>
    <div class="wrapper">
        <div class="card">
            <div class="card-header">
                <img src="/static/images/izuk%20(1).png?v=<%= appVersion %>" alt="飯塚塗研" class="card-logo">
                <div class="card-tagline">Your vision, our future</div>
            </div>
            <div class="card-content">
                <div id="error" role="alert" aria-live="assertive"></div>
                <form id="loginForm" novalidate method="post">
                    <div class="form-row">
                        <span class="form-icon">
                            <svg viewBox="0 0 24 24">
                                <circle cx="12" cy="8" r="4" />
                                <path d="M4 20c0-4 4-6 8-6s8 2 8 6" />
                            </svg>
                        </span>
                        <span class="form-label-ja"><img src="/static/images/hinhuse.png?v=20260509-login1" alt="" class="label-icon-img label-icon-img-user">ユーザ名</span>
                        <div class="input-with-icon">
                            <input id="email" name="login_email" type="email" placeholder="" autocomplete="off" autocapitalize="none" spellcheck="false" class="short-input" required>
                        </div>
                    </div>
                    <div class="form-row">
                        <span class="form-icon">
                            <svg viewBox="0 0 24 24">
                                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                                <rect x="5" y="11" width="14" height="10" rx="2" />
                            </svg>
                        </span>
                        <span class="form-label-ja"><img src="/static/images/pasword.png?v=<%= appVersion %>" alt="" class="label-icon-img label-icon-img-pass">パスワード</span>
                        <div class="input-with-icon">
                            <input id="password" name="login_password" type="password" placeholder="" autocomplete="off" class="short-input" required>
                            <button type="button" id="togglePassword" class="icon-btn" aria-label="toggle"></button>
                        </div>
                    </div>

                    <div class="terms-note">
                        <a id="termsLinkInline" href="/terms?v=<%= appVersion %>" onclick="window.location.assign('/terms'); return false;">利用規約</a>と
                        <a id="privacyLinkInline" href="/privacy?v=<%= appVersion %>" onclick="window.location.assign('/privacy'); return false;">個人情報の取り扱い</a>について同意の上<br>
                        <span>ログインしてください。</span>
                    </div>
                    <div class="form-row actions">
                        <button type="submit" id="loginBtn" class="btn">ログイン</button>
                    </div>
                    <div class="notes">
                        注意<br>
                        ※ユーザ名：ご自分のメールアドレス<br>
                        ※パスワード：ご自身で設定されたパスワード
                    </div>
                    <div id="success"></div>
                    <div id="status" aria-live="polite"></div>
                </form>
            </div>
        </div>
        <div class="circle">
            <ul>
                <li><a href="/forgot-password" onclick="window.location.assign('/forgot-password'); return false;">パスワードをお忘れの方はこちら</a></li>
                <li><a id="termsLinkCircle" href="/terms?v=<%= appVersion %>" onclick="window.location.assign('/terms'); return false;">利用規約</a></li>
                <li><a id="privacyLinkCircle" href="/privacy?v=<%= appVersion %>" onclick="window.location.assign('/privacy'); return false;">個人情報の取り扱いについて</a></li>
            </ul>
        </div>
    </div>
</body>

</html>


