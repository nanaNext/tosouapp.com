<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FAQ System - Manual Test</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
            background: #f5f5f5;
        }
        .test-section {
            background: white;
            padding: 15px;
            margin: 10px 0;
            border-radius: 5px;
            border-left: 4px solid #1e40af;
        }
        .test-result {
            padding: 10px;
            margin: 10px 0;
            border-radius: 3px;
            font-weight: bold;
        }
        .success {
            background: #dcfce7;
            color: #166534;
        }
        .error {
            background: #fee2e2;
            color: #991b1b;
        }
        button {
            background: #1e40af;
            color: white;
            padding: 10px 20px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
        }
        button:hover {
            background: #1e3a8a;
        }
        .log {
            background: #f9f9f9;
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 3px;
            max-height: 300px;
            overflow-y: auto;
            font-size: 12px;
            font-family: monospace;
            white-space: pre-wrap;
            word-wrap: break-word;
        }
    </style>
</head>
<body>
    <h1>FAQ System - Manual Test</h1>
    
    <div class="test-section">
        <h2>1. API Test</h2>
        <button onclick="testGetAllQuestions()">GET /api/faq/admin/questions</button>
        <div id="apiResult"></div>
    </div>

    <div class="test-section">
        <h2>2. Page Navigation Test</h2>
        <button onclick="navigateToFaq()">Navigate to /admin/faq</button>
        <div id="navResult"></div>
    </div>

    <div class="test-section">
        <h2>3. Component Mount Test</h2>
        <button onclick="testComponentMount()">Test Component Mount</button>
        <div id="mountResult"></div>
    </div>

    <div class="test-section">
        <h2>Logs</h2>
        <div id="logs" class="log">Ready for testing...</div>
    </div>

    <script>
        const log = (msg) => {
            const logsEl = document.getElementById('logs');
            const time = new Date().toLocaleTimeString();
            logsEl.innerHTML += `[${time}] ${msg}\n`;
            logsEl.scrollTop = logsEl.scrollHeight;
        };

        async function testGetAllQuestions() {
            const resultEl = document.getElementById('apiResult');
            resultEl.innerHTML = '<div class="test-result">Testing...</div>';
            log('📥 Testing GET /api/faq/admin/questions');
            
            try {
                const response = await fetch('/api/faq/admin/questions', {
                    credentials: 'include'
                });
                
                log(`📊 Response status: ${response.status}`);
                
                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}`);
                }
                
                const data = await response.json();
                log(`✅ API Success! Got ${data.data?.length || 0} questions`);
                resultEl.innerHTML = `
                    <div class="test-result success">
                        ✅ API Working!<br>
                        Questions: ${data.data?.length || 0}<br>
                        Response: <pre>${JSON.stringify(data, null, 2)}</pre>
                    </div>
                `;
            } catch (e) {
                log(`❌ API Error: ${e.message}`);
                resultEl.innerHTML = `<div class="test-result error">❌ Error: ${e.message}</div>`;
            }
        }

        function navigateToFaq() {
            const resultEl = document.getElementById('navResult');
            log('🔗 Navigating to /admin/faq');
            resultEl.innerHTML = '<div class="test-result">Navigating...</div>';
            
            try {
                window.location.href = '/admin/faq';
                log('✅ Navigation initiated');
                resultEl.innerHTML = '<div class="test-result success">✅ Navigating to /admin/faq</div>';
            } catch (e) {
                log(`❌ Navigation Error: ${e.message}`);
                resultEl.innerHTML = `<div class="test-result error">❌ Error: ${e.message}</div>`;
            }
        }

        async function testComponentMount() {
            const resultEl = document.getElementById('mountResult');
            resultEl.innerHTML = '<div class="test-result">Testing...</div>';
            log('🧪 Testing component mount');
            
            try {
                // Test loading the module
                const mod = await import('/static/js/admin/faq/faq.page.js?v=navy-20260427-faqfix1');
                log('✅ Module loaded successfully');
                
                // Create a test container
                const testContainer = document.createElement('div');
                testContainer.id = 'adminContent';
                testContainer.style.border = '2px solid #1e40af';
                testContainer.style.padding = '20px';
                testContainer.style.marginTop = '20px';
                
                resultEl.appendChild(testContainer);
                
                // Try to mount
                if (mod && typeof mod.mount === 'function') {
                    log('📦 Mount function found, attempting mount...');
                    const cleanup = await mod.mount();
                    log('✅ Component mounted successfully!');
                    resultEl.innerHTML += `<div class="test-result success">✅ Component Mounted!</div>`;
                } else {
                    throw new Error('Mount function not found in module');
                }
            } catch (e) {
                log(`❌ Component Error: ${e.message}`);
                resultEl.innerHTML += `<div class="test-result error">❌ Error: ${e.message}</div>`;
            }
        }

        log('Page loaded. Ready to test FAQ system.');
    </script>
</body>
</html>
